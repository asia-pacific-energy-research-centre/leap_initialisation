                <mxCell id="3Vn5BuMNg00IzMXtSu-n-76" value="&lt;b&gt;Costs&lt;/b&gt;&lt;div&gt;Through LEAP or excel, develop estimates of major energy related costs, especially in power.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="-340" y="330" width="280" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="3Vn5BuMNg00IzMXtSu-n-77" value="&lt;b&gt;Emissions and indicator development:&lt;/b&gt;&lt;div&gt;- emissions: simple emissions factor times energy use calculation&amp;nbsp;&lt;/div&gt;&lt;div&gt;- APEC goals&lt;/div&gt;&lt;div&gt;- common indicators&lt;/div&gt;&lt;div&gt;- key takeaways&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="-340" y="430" width="280" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="3Vn5BuMNg00IzMXtSu-n-78" value="LEAP export&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(74, 61, 51), rgb(192, 181, 173)); background-color: transparent;&quot;&gt;→ energy balances format → visualisation, indicators and analysis" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontStyle=1;spacing=10;fillColor=#F3F1EC;strokeColor=#8C7B6D;fontColor=#000000;fontSize=16;" parent="1" vertex="1">
                    <mxGeometry x="1440" y="620" width="160" height="156" as="geometry"/>
