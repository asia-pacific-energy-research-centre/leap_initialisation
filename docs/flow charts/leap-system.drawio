                <mxCell id="E_T_TO_AREA" value="Sector model import" style="edgeStyle=orthogonalEdgeStyle;orthogonalLoop=1;jettySize=auto;endArrow=block;html=1;rounded=0;labelBackgroundColor=#ffffff;fontSize=14;" parent="1" target="LEAP_AREA" edge="1">
