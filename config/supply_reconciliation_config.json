{
    "_instructions": {
        "description": "Configuration for the CAPACITY_UNMET iterative balanced pass in supply_reconciliation_workflow.py. Edit this file to adjust which transformation modules can grow, how much production is allowed, and which module gets priority when multiple modules supply the same fuel.",
        "sentinel_values": {
            "_note": "Use these string values instead of raw numbers to make intent clear.",
            "module_cap_sentinels": {
                "UNLIMITED": "No cap — module may grow freely. Same as omitting the entry entirely.",
                "KEEP_EXOGENOUS_CAP_SAME_AS_BASE_YEAR_ENERGY_OUTPUT": "Cap = ESTO base-year output. Module cannot grow beyond its current level.",
                "DECREASE_TO_ZERO": "Cap = 0. Block all capacity additions for this module.",
                "INCREASE_BY_PCT(x)": "Cap = base-year output × (1 + x/100). Example: \"INCREASE_BY_PCT(20)\" allows 20% growth.",
                "DECREASE_BY_PCT(x)": "Cap = base-year output × (1 - x/100). Example: \"DECREASE_BY_PCT(50)\" halves the cap.",
                "SET_CAP_TO(value)": "Explicit numeric cap in PJ. Use sparingly; prefer the relative sentinels."
            },
            "production_cap_sentinels": {
                "UNLIMITED_PRODUCTION": "No cap — production may grow freely. Same as omitting the entry.",
                "KEEP_PRODUCTION_AT_BASE_YEAR": "Cap = base-year constrained production. No new production headroom.",
                "DECREASE_PRODUCTION_TO_ZERO": "Zero out production headroom entirely.",
                "INCREASE_PRODUCTION_BY_PCT(x)": "Base-year constrained production × (1 + x/100).",
                "DECREASE_PRODUCTION_BY_PCT(x)": "Base-year constrained production × (1 - x/100).",
                "SET_PRODUCTION_CAP_TO(value)": "Explicit numeric cap in PJ (same units as the balance table)."
            }
        },
        "priority_by_product": {
            "_note": "CAPACITY_UNMET_PRIORITY_BY_PRODUCT — required for any ESTO product produced by 2+ transformation modules. First module in the list gets headroom allocated first. Products with only one module do not need an entry. If a multi-module product is missing the workflow raises at startup and prints exactly what to add."
        },
        "module_capacity_upper_limits": {
            "_note": "CAPACITY_UNMET_MODULE_CAPACITY_UPPER_LIMITS — shape: economy → scenario → module_name → sentinel or raw number. Module names must match the 'module' column of process_catalog (case-insensitive). Comment out or delete a line to remove the cap and revert to UNLIMITED."
        },
        "production_upper_limits": {
            "_note": "CAPACITY_UNMET_PRODUCTION_UPPER_LIMITS — shape: economy → scenario → esto_product → sentinel or raw number. Keys are matched with the leading ESTO numeric code stripped, so '08.01 Natural gas' and 'Natural gas' both match. Comment out or delete a line to remove the cap."
        }
    },

